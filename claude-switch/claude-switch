#!/usr/bin/env bash
set -euo pipefail

CLAUDE_DIR="${HOME}/.claude"
AUTH_DIR="${CLAUDE_DIR}/auth"

print_help() {
  cat <<'EOF'
Usage:
  claude-switch list
  claude-switch <profile>
  claude-switch register <name>
  claude-switch install [shell]

Description:
  Switch between different Claude configurations.

  Configurations are stored in ~/.claude/auth/<profile>/
  When switching, files from the profile directory are copied to ~/.claude/

Examples:
  claude-switch list           # List available profiles
  claude-switch itptg          # Switch to 'itptg' profile
  claude-switch register new   # Create a new profile directory
  claude-switch install zsh    # Install shell completions
EOF
}

list_profiles() {
  if [ ! -d "${AUTH_DIR}" ]; then
    echo "No profiles directory found: ${AUTH_DIR}"
    echo "Use 'claude-switch register <name>' to create a profile"
    return
  fi

  local profiles=()
  for entry in "${AUTH_DIR}"/*; do
    [ -d "${entry}" ] && profiles+=("$(basename "${entry}")")
  done

  if [ ${#profiles[@]} -eq 0 ]; then
    echo "No profiles found in ${AUTH_DIR}"
    echo "Use 'claude-switch register <name>' to create a profile"
  else
    echo "Available profiles:"
    for profile in "${profiles[@]}"; do
      echo "  - ${profile}"
    done
  fi
}

register_profile() {
  local name="$1"
  local profile_dir="${AUTH_DIR}/${name}"

  if [ -d "${profile_dir}" ]; then
    echo "Profile '${name}' already exists: ${profile_dir}"
    return 1
  fi

  mkdir -p "${profile_dir}"
  echo "✓ Registered profile: ${name}"
  echo "  Directory: ${profile_dir}"
  echo "  Place your configuration files (settings.json, etc.) in this directory"
}

switch_profile() {
  local profile="$1"
  local profile_dir="${AUTH_DIR}/${profile}"

  if [ ! -d "${profile_dir}" ]; then
    echo "Error: Profile '${profile}' not found" >&2
    echo "Available profiles:" >&2
    for entry in "${AUTH_DIR}"/*; do
      [ -d "${entry}" ] && echo "  - $(basename "${entry}")" >&2
    done
    return 1
  fi

  local copied=0
  for file in "${profile_dir}"/*; do
    [ -f "${file}" ] || continue
    local filename="$(basename "${file}")"
    cp "${file}" "${CLAUDE_DIR}/${filename}"
    echo "✓ Copied ${filename}"
    ((copied++)) || true
  done

  if [ ${copied} -eq 0 ]; then
    echo "Warning: No files found in ${profile_dir}"
  else
    echo "✓ Switched to profile: ${profile}"
  fi
}

install_completions() {
  local shell="${1:-zsh}"
  local marker="# claude-switch completions"

  case "${shell}" in
    zsh)
      local zshrc="${HOME}/.zshrc"
      if grep -q "${marker}" "${zshrc}" 2>/dev/null; then
        echo "Completions already installed in ${zshrc}"
        return
      fi
      cat >> "${zshrc}" <<'EOF'

# claude-switch completions
_claude_switch_completions() {
    local -a profiles
    if [[ -d ~/.claude/auth ]]; then
        profiles=(${(f)"$(ls -1 ~/.claude/auth 2>/dev/null)"})
    fi
    _describe 'profile' profiles
}
compdef _claude_switch_completions claude-switch
EOF
      echo "✓ Completions installed to ${zshrc}"
      echo "  Run 'source ~/.zshrc' to activate"
      ;;
    bash)
      local bashrc="${HOME}/.bashrc"
      if grep -q "${marker}" "${bashrc}" 2>/dev/null; then
        echo "Completions already installed in ${bashrc}"
        return
      fi
      cat >> "${bashrc}" <<'EOF'

# claude-switch completions
_claude_switch_completions() {
    local cur="${COMP_WORDS[COMP_CWORD]}"
    local profiles=""
    if [[ -d ~/.claude/auth ]]; then
        profiles=$(ls -1 ~/.claude/auth 2>/dev/null)
    fi
    COMPREPLY=($(compgen -W "$profiles" -- "$cur"))
}
complete -F _claude_switch_completions claude-switch
EOF
      echo "✓ Completions installed to ${bashrc}"
      echo "  Run 'source ~/.bashrc' to activate"
      ;;
    fish)
      local fish_comp="${HOME}/.config/fish/completions/claude-switch.fish"
      mkdir -p "$(dirname "${fish_comp}")"
      cat > "${fish_comp}" <<'EOF'
# claude-switch completions
complete -c claude-switch -f
complete -c claude-switch -a "(ls ~/.claude/auth 2>/dev/null)"
EOF
      echo "✓ Completions installed to ${fish_comp}"
      ;;
    *)
      echo "Error: Unsupported shell: ${shell}" >&2
      echo "Supported shells: zsh, bash, fish" >&2
      return 1
      ;;
  esac
}

if [ $# -eq 0 ]; then
  print_help
  exit 1
fi

case "$1" in
  -h|--help)
    print_help
    exit 0
    ;;
  list)
    list_profiles
    ;;
  register)
    if [ $# -lt 2 ]; then
      echo "Error: Missing profile name" >&2
      echo "Usage: claude-switch register <name>" >&2
      exit 1
    fi
    register_profile "$2"
    ;;
  install)
    install_completions "${2:-zsh}"
    ;;
  *)
    switch_profile "$1"
    ;;
esac